{
  "name": "lottery-booking-frontend",
  "version": "0.1.3",
  "private": true,
  "homepage": ".",
  "main": "electron/main.js",
  "dependencies": {
    "axios": "^1.4.0",
    "electron-updater": "^6.8.3",
    "pdfjs-dist": "^3.11.174",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.11.0",
    "react-scripts": "5.0.1",
    "tesseract.js": "^5.1.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "electron": "electron electron/main.js",
    "electron:dev": "set ELECTRON_START_URL=http://localhost:3000&& electron electron/main.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "devDependencies": {
    "electron": "41.5.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "extends": null,
    "appId": "com.lottery.booking",
    "productName": "Lottery Booking",
    "asar": true,
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "artifactName": "Lottery-Booking-Setup-${version}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "RAHUL04557",
        "repo": "Rahul-LOTTERY"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
